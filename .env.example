# =============================================================================
# Precision Biomarker Agent — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# Required: Anthropic API key for Claude LLM
ANTHROPIC_API_KEY=

# Milvus connection (defaults shown)
BIOMARKER_MILVUS_HOST=localhost
BIOMARKER_MILVUS_PORT=19530

# API server (defaults shown)
BIOMARKER_API_HOST=0.0.0.0
BIOMARKER_API_PORT=8529

# Streamlit UI port (configured in .streamlit/config.toml)
# Default: 8528

# Embedding model (default shown)
BIOMARKER_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# LLM model (default shown)
BIOMARKER_LLM_MODEL=claude-sonnet-4-20250514

# CORS origins (comma-separated)
BIOMARKER_CORS_ORIGINS=http://localhost:8080,http://localhost:8528,http://localhost:8529
