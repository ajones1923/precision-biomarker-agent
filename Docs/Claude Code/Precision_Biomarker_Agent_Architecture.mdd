flowchart TB
    %% ── Styling ──────────────────────────────────────────────
    classDef inputNode fill:#E8F4F8,stroke:#1AAFCC,stroke-width:2px,color:#1B2333,font-weight:bold
    classDef vastNode fill:#F0FBFD,stroke:#1AAFCC,stroke-width:2px,color:#1B2333
    classDef nvidiaNode fill:#EFF8E8,stroke:#76B900,stroke-width:2px,color:#1B2333
    classDef planeLabel fill:#1B2333,stroke:#1B2333,color:#FFFFFF,font-weight:bold
    classDef workflowNode fill:#FFF8E1,stroke:#F5A623,stroke-width:2px,color:#1B2333
    classDef outputNode fill:#F3E8FF,stroke:#7C3AED,stroke-width:2px,color:#1B2333
    classDef clinicalNode fill:#FEE2E2,stroke:#DC2626,stroke-width:2px,color:#1B2333,font-weight:bold
    classDef factoryNode fill:#E0E7FF,stroke:#4338CA,stroke-width:2px,color:#1B2333,font-weight:bold
    classDef canonNode fill:#D1FAE5,stroke:#059669,stroke-width:2px,color:#1B2333,font-weight:bold

    %% ── Biomarker Sources ───────────────────────────────────
    subgraph SOURCES["  🩸  Biomarker Sources  "]
        direction LR
        BLOOD["🧪 Comprehensive Blood Panels\n(160+ analytes · CBC · CMP\nLipids · Liver · Thyroid\nInflammation · Nutrients)"]
        GENOMIC["🧬 Genomic Variants\n(15 disease-risk loci\n4 pharmacogenomic genes\nStar alleles · Zygosity)"]
        MCED["🔬 Galleri MCED\n(Multi-Cancer Early Detection\nCell-free DNA signal)"]
    end
    BLOOD:::inputNode
    GENOMIC:::inputNode
    MCED:::inputNode

    %% ── Data Ingestion ──────────────────────────────────────
    subgraph INGEST["  Data Ingestion  "]
        direction LR
        HL7["HL7 / FHIR\nLab Results"]
        VCF["VCF / gVCF\nGenomic Variants"]
        CSV["Structured CSV\nPanel Imports"]
        GALLERI["Galleri Report\nIngestion"]
    end
    HL7:::vastNode
    VCF:::vastNode
    CSV:::vastNode
    GALLERI:::vastNode

    %% ══════════════════════════════════════════════════════════
    %% VAST AI OS — Three-Plane Architecture
    %% ══════════════════════════════════════════════════════════
    subgraph VASTOS["  VAST AI OS  —  Biomarker Intelligence Agent Substrate  "]

        %% ── Data Plane ───────────────────────────────────────
        subgraph DATAPLANE["  ① Data Plane  "]
            direction TB
            DATASTORE["DataStore (DASE)\nSustained throughput for\nrepeated correlation analysis"]
            DATASPACE["DataSpace\nGlobal namespace\n(edge · core · cloud)"]
            subgraph CANONICAL["  Canonical Biomarker Profile  "]
                direction LR
                RAW_PANELS["Raw Lab Panels\n(immutable source values\n160+ analytes)"]
                GENO_STATE["Genomic Context\n15 disease-risk variants\n4 PGx genes · Zygosity"]
                DERIVED_IDX["Derived Indices\nPhenoAge · GrimAge\nDisease risk scores"]
                ADJUSTED["Genotype-Adjusted\nReference Ranges\nPersonalized thresholds"]
                PROV["Provenance Bundles\nPipeline version · Params\nLineage · Timestamps"]
            end
        end
        DATASTORE:::vastNode
        DATASPACE:::vastNode
        RAW_PANELS:::canonNode
        GENO_STATE:::canonNode
        DERIVED_IDX:::canonNode
        ADJUSTED:::canonNode
        PROV:::canonNode

        %% ── Execution Plane ──────────────────────────────────
        subgraph EXECPLANE["  ② Execution Plane  "]
            direction TB
            DATAENGINE["DataEngine\nEvent-driven orchestration\npanel.complete → pipeline trigger"]

            subgraph NVSTACK["  NVIDIA Accelerated Computing  "]
                direction LR
                DGX["DGX Spark → SuperPOD\nGPU compute substrate"]
                PARABRICKS["Parabricks 4.6\nVariant calling\nAnnotation pipeline"]
                MED42["Med42-70B\nClinical reasoning\nEvidence synthesis"]
                NIM["NVIDIA NIM\nInference microservices\nVersioned · Auto-scaling"]
            end

            FLARE["NVIDIA FLARE\nFederated learning\nacross institutions"]
        end
        DATAENGINE:::vastNode
        DGX:::nvidiaNode
        PARABRICKS:::nvidiaNode
        MED42:::nvidiaNode
        NIM:::nvidiaNode
        FLARE:::nvidiaNode

        %% ── Reasoning Plane ──────────────────────────────────
        subgraph REASONPLANE["  ③ Reasoning Plane  "]
            direction LR
            DATABASE["DataBase\nUnified SQL + Vector\nQuery Plane"]
            INSIGHT["InsightEngine\nRAG reasoning\nEvidence grounding"]
            LONGITUDINAL["Longitudinal\nComparison\nTrend detection\nDelta analysis"]
            COHORTS["Cohort Retrieval\nEmbedding similarity\nPatients-like-this"]
        end
        DATABASE:::vastNode
        INSIGHT:::vastNode
        LONGITUDINAL:::vastNode
        COHORTS:::vastNode
    end

    %% ── Seven Core Analysis Modules ─────────────────────────
    subgraph MODULES["  Analysis Modules  —  Seven-Stage Intelligence  "]
        direction LR
        M_AGE["Biological Age\nEngine\nPhenoAge · GrimAge\n9 biomarkers + DNAm"]
        M_DISEASE["Pre-Symptomatic\nDisease Detection\nTrajectory scoring\nEarly signal capture"]
        M_CARDIO["Advanced\nCardiovascular\nLp(a) · ApoB · hsCRP\nGenotype-stratified risk"]
        M_GENOADJ["Genotype-Adjusted\nReference Ranges\nPersonalized thresholds\n6+ reclassifications"]
        M_PGX["Pharmacogenomic\nMapping\nCPIC guidelines\n8 drug classes"]
        M_INTERV["Intervention\nPlanning\nPrioritized actions\nMonitoring schedule"]
        M_INFLAM["Inflammatory\nPhenotyping\nIL-6 · TNF-α · hsCRP\nAutoimmune screening"]
    end
    M_AGE:::workflowNode
    M_DISEASE:::workflowNode
    M_CARDIO:::workflowNode
    M_GENOADJ:::workflowNode
    M_PGX:::workflowNode
    M_INTERV:::workflowNode
    M_INFLAM:::workflowNode

    %% ── Clinical Output Encoding ─────────────────────────────
    subgraph OUTPUTS["  Clinical Output Encoding  "]
        direction LR
        FHIR_OUT["FHIR\nDiagnostic\nReport"]
        REPORT["Precision\nBiomarker\nReport"]
        ALERTS["Critical\nValue\nAlerts"]
        MONITOR["Monitoring\nSchedule\n& Retest Plan"]
    end
    FHIR_OUT:::outputNode
    REPORT:::outputNode
    ALERTS:::outputNode
    MONITOR:::outputNode

    %% ── Clinical Destinations ────────────────────────────────
    subgraph CLINICAL["  Clinical Systems  "]
        direction LR
        EHR["EHR"]
        CLINICIAN["Clinician\nClinician-in-the-Loop\nDecision Support"]
        PATIENT["Patient Portal\nPersonalized\nHealth Intelligence"]
    end
    EHR:::clinicalNode
    CLINICIAN:::clinicalNode
    PATIENT:::clinicalNode

    %% ── HCLS AI Factory (broader platform) ───────────────────
    subgraph FACTORY["  HCLS AI Factory  —  Multimodal Patient Care  "]
        direction LR
        IMAGING["Imaging Agent\nCT · MRI · X-Ray\nStructured findings"]
        GENOMICS["Genomics Pipeline\nParabricks\nSomatic · Germline"]
        DRUGDISC["Drug Discovery\nBioNeMo\nCandidate Scoring"]
    end
    IMAGING:::factoryNode
    GENOMICS:::factoryNode
    DRUGDISC:::factoryNode

    %% ══════════════════════════════════════════════════════════
    %% CONNECTIONS
    %% ══════════════════════════════════════════════════════════

    %% Ingestion flow
    SOURCES --> INGEST
    INGEST --> DATASTORE

    %% Data Plane internal
    DATASTORE <--> DATASPACE
    DATASTORE --> CANONICAL

    %% Data → Execution
    CANONICAL --> DATAENGINE
    DATAENGINE --> NVSTACK
    FLARE -.->|"Multi-site model\nimprovement"| NVSTACK

    %% Execution → Canonical (outputs persisted)
    NVSTACK -->|"Derived indices\npersisted back"| CANONICAL

    %% Execution → Modules
    NVSTACK --> MODULES

    %% Data → Reasoning
    CANONICAL --> DATABASE
    DERIVED_IDX --> COHORTS
    DATASPACE -->|"Prior panel\nretrieval"| LONGITUDINAL

    %% Reasoning feeds Modules
    REASONPLANE -->|"Evidence · Priors\nCohort context"| MODULES

    %% Modules → Output Encoding
    MODULES --> OUTPUTS

    %% Output → Clinical
    FHIR_OUT --> EHR
    REPORT --> CLINICIAN
    ALERTS --> CLINICIAN
    MONITOR --> PATIENT

    %% ── Cross-Modal Links to HCLS AI Factory ─────────────────
    GENO_STATE -->|"Variant context\nenriches genomic\nworkflow"| GENOMICS
    GENOMICS -->|"Molecular context\nenriches biomarker\nfindings"| INSIGHT
    INSIGHT <--> IMAGING
    GENOMICS --> DRUGDISC
    M_DISEASE -.->|"Pre-symptomatic\nsignal triggers\nconfirmatory imaging"| IMAGING
    DRUGDISC -.->|"Candidate scoring\nfor treatment\nstratification"| INSIGHT

    %% Governance annotation
    PROV -.->|"Audit trail · Reproducibility\nPredetermined change control"| CLINICIAN
